<script src="servers.js?n=1"></script>
<script>
function serverLoad() {
	var idCounter = 0
	var maxCount = 0
	var sharedCount = 0
	function getProject() {
		if (idCounter < 1) {
			document.getElementById("explore").innerHTML = "";
		}
	}
	servers.readFile("ggm-community-all-projects.txt",function (data) {
		document.getElementById("explore").innerHTML = "";
		var projectsArray = JSON.parse(data).projects;
		function makeProjectDiv(thubanilsrc,id) {
			var b = document.createElement("button");
			var a = document.createElement("a");
			a.href = "player.html?id="+id;
			a.appendChild(b);
			document.getElementById("explore").appendChild(a);
			if (json.thumb) {
				b.innerHTML = json.title+"<br><img src='"+thubanilsrc+"' width=160 height=100>  ";
			} else {
				b.innerHTML = json.title+"<br><br><br><p>No Thumbanil Avaiable.</p><br><br>";
			}
			b.setAttribute("class","project");
			b.setAttribute("id",idCounter);
			return a;
		}
		for (var i in projectsArray.length) {
			var div = makeProjectDiv(projectsArray[i].thumbanil,projectsArray[i].id);
			div.onclick 
		}
		
	});
}
//servers.wsobject.onopen = serverLoad;
//don't wait for the ws server to open, we replaced it with firebase!
serverLoad();
</script>
