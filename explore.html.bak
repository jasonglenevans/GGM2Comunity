<!DOCTYPE HTML>
<html>
<head>

<title>Gvbvdxx game maker 2 commuinity!</title>
<style>
	#main_menu {
		position:fixed;
		top:0;
		left:0;
		background-color:#339af0;
		width:100%;
		height:48px;
	}
	.main_menu_item {
		font-weight:bold;
		color:#ffffff;
		cursor:pointer;
		float:left;
		margin-left:15px;
	}
	.main_menu_item:hover {
		font-size:20px;
		margin-top:13px;
	}
	html {
		background-color:#edf2ff;
		font-family:Arial;
	}
	.project {
		border:none;
		width:100%;
		height:40px;
		background-color:#0085b5;
		border-left-style:solid;
		border-left-color:blue;
		color:white;
		font-weight:bold;
	}
	.project:hover {
		background-color:#24b8ed;
		cursor:pointer;
	}
</style>
</head>
<body>

<div id="main_menu">
<img width=100 height=48 style="float:left;" src="./logo.png">
<a href="editor/index.html"><p class="main_menu_item">Create</p></a>
<a href="explore.html"><p class="main_menu_item">Explore</p></a>
</div>
<br></br>
<center>

<h1>Explore</h1>
<!--<label for="seartch">Find:</label>
<input type="text" id="seartch">-->
<hr>
<div id="explore"></div>
<p id="loading">Loading projects...</p>
</center>
<script src="servers.js?n=1"></script>
<script>
var idCounter = 0
var maxCount = 0
function getProject() {
	servers.readFile("ggm-community-accountid-project-"+idCounter+".ggm2gserver",function (data) {
		try{
			var json = JSON.parse(data)
			var b = document.createElement("button");
			var a = document.createElement("a");
			a.href = "editor/index.html?id="+idCounter;
			a.appendChild(b);
			document.getElementById("explore").appendChild(a);
			b.innerHTML = ""+json.title+"";
			b.setAttribute("class","project");
			b.setAttribute("id",idCounter);
			document.getElementById("explore").innerHTML += "<br><br>";
		}catch(e){}
		if (idCounter < maxCount) {
			idCounter += 1
			getProject()
		} else {
			document.getElementById("loading").hidden = true;
		}
	});
}
servers.readFile("ggm-community-accountid-latest-id.txt",function (data) {
	maxCount = Number(data);
	getProject()
});
</script>

</body>
</html>